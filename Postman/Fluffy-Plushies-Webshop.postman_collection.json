    {
      "name": "Auth",
      "item": [
        {
          "name": "Login User",
          "event": [
            {
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"userToken\", jsonData.token);",
                  "const base64Payload = jsonData.token.split(\".\")[1].replace(/-/g, \"+\").replace(/_/g, \"/\");",
                  "const paddedPayload = base64Payload.padEnd(base64Payload.length + (4 - base64Payload.length % 4) % 4, \"=\");",
                  "const payload = JSON.parse(atob(paddedPayload));",
                  "pm.collectionVariables.set(\"userId\", payload.sub);"
                ]
              },
              "listen": "test"
            }
          ],
          "id": "5aa5da57-6d9b-4c1e-8317-0813aa8563ee",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"user\",\r\n  \"password\": \"{{userPassword}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrlIdentity}}/auth/login",
              "host": [
